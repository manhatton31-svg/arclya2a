# Arclya A2A — local development environment variables
# Copy to .env and fill in values:  cp .env.example .env
# Never commit .env (it is gitignored). On Render, set these in the dashboard instead.

# ── Core API keys ─────────────────────────────────────────────────────────────
# xAI inference (required for live LLM calls; tests use mocks)
XAI_API_KEY=

# Platform API key for external agents (unset = auth disabled for local dev)
ARCLYA_API_KEY=

# Operator key for graduation and privileged actions (min 8 chars in production)
ARCLYA_OPERATOR_KEY=

# ── Server / deployment ───────────────────────────────────────────────────────
# Public URL for Agent Card discovery (Render sets RENDER_EXTERNAL_URL automatically)
ARCLYA_PUBLIC_URL=
# PORT is set by Render; local default comes from config/core.json
# PORT=8787

ARCLYA_RATE_LIMIT_PER_MINUTE=60
ARCLYA_JSON_LOGS=0

# ── Sandbox partners ──────────────────────────────────────────────────────────
ARCLYA_SANDBOX_MAX_KEYS_PER_AGENT=2
ARCLYA_SANDBOX_MAX_REGISTER_PER_IP_DAY=5
ARCLYA_SANDBOX_RATE_LIMIT_PER_MINUTE=10
ARCLYA_SANDBOX_FORCE_DRY_RUN=1
# Sandbox/rehearsal: one agent per handoff-chain (skips guardrails; stays under Render ~30s limit)
ARCLYA_REHEARSAL_MODE=1

# ── Tools & connectors ────────────────────────────────────────────────────────
ARCLYA_TOOL_DRY_RUN=1
ARCLYA_TOOL_MAX_RETRIES=3
ARCLYA_TOOL_RETRY_BASE_MS=500

# ── Learning scheduler ────────────────────────────────────────────────────────
ARCLYA_LEARNING_SCHEDULER_ENABLED=0
ARCLYA_LEARNING_INTERVAL_HOURS=6
ARCLYA_LEARNING_MIN_DEALS=0
ARCLYA_LEARNING_CHECK_SECONDS=300
ARCLYA_AUTO_APPLY_LOW_RISK=1
ARCLYA_AUTO_APPLY_MIN_CONFIDENCE=0.75

# ── Security & isolation ──────────────────────────────────────────────────────
ARCLYA_ISOLATION_MIN_ACTORS=2

# ── Partner graduation ────────────────────────────────────────────────────────
ARCLYA_GRADUATION_WEBHOOK_URL=

# ── Crypto payments (foundation — no on-chain verification yet) ─────────────
# Public RECEIVE addresses only. Do NOT put private keys or seed phrases here.
ARCLYA_CRYPTO_ENABLED=0
ARCLYA_CRYPTO_TOKEN=USDC
# Default network when a payment intent does not specify one
ARCLYA_CRYPTO_NETWORK=base
# Comma-separated accepted networks (base, ethereum, solana, bnb)
ARCLYA_CRYPTO_NETWORKS=base,ethereum,solana,bnb
# Per-network USDC receive addresses (set each chain you want to accept)
ARCLYA_CRYPTO_WALLET_BASE=
ARCLYA_CRYPTO_WALLET_ETHEREUM=
ARCLYA_CRYPTO_WALLET_SOLANA=
ARCLYA_CRYPTO_WALLET_BNB=
# Legacy single-wallet fallback (maps to ARCLYA_CRYPTO_NETWORK only)
ARCLYA_CRYPTO_WALLET_ADDRESS=
ARCLYA_CRYPTO_MIN_AMOUNT_USD=10
ARCLYA_CRYPTO_INTENT_EXPIRY_HOURS=24

# ── Crypto Test Payer agent (optional round-trip checkout tests) ─────────────
# Public receive wallet for the test agent (defaults to ARCLYA_CRYPTO_WALLET_BASE)
ARCLYA_CRYPTO_TEST_PAYER_WALLET=
# Where surplus USDC is refunded after a test checkout (your personal address)
ARCLYA_CRYPTO_TEST_PAYER_REFUND_ADDRESS=
# LOCAL ONLY — never commit. Required for automated USDC refunds on Base.
ARCLYA_CRYPTO_TEST_PAYER_PRIVATE_KEY=
ARCLYA_BASE_RPC_URL=https://mainnet.base.org