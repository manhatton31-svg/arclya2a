{
  "name": "delete-many",
  "description": "Removes all documents that match the filter from a MongoDB collection",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "database": {
        "type": "string"
      },
      "collection": {
        "type": "string"
      },
      "filter": {
        "type": "object",
        "properties": {},
        "additionalProperties": {}
      }
    },
    "required": [
      "database",
      "collection"
    ]
  }
}