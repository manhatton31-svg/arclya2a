{
  "name": "rename-collection",
  "description": "Renames a collection in a MongoDB database",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "database": {
        "type": "string"
      },
      "collection": {
        "type": "string"
      },
      "newName": {
        "type": "string"
      },
      "dropTarget": {
        "default": false,
        "type": "boolean"
      }
    },
    "required": [
      "database",
      "collection",
      "newName"
    ]
  }
}