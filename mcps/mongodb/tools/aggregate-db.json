{
  "name": "aggregate-db",
  "description": "Run an aggregation against a MongoDB database",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "database": {
        "type": "string"
      },
      "pipeline": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {},
          "additionalProperties": {}
        }
      },
      "responseBytesLimit": {
        "default": 1048576,
        "type": "number"
      }
    },
    "required": [
      "database",
      "pipeline"
    ]
  }
}