{
  "name": "find",
  "description": "Run a find query against a MongoDB collection",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "database": {
        "type": "string"
      },
      "collection": {
        "type": "string"
      },
      "filter": {
        "type": "object",
        "properties": {},
        "additionalProperties": {}
      },
      "projection": {
        "type": "object",
        "properties": {},
        "additionalProperties": {}
      },
      "limit": {
        "default": 10,
        "type": "number"
      },
      "sort": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {
          "anyOf": [
            {
              "type": "number",
              "const": 1
            },
            {
              "type": "number",
              "const": -1
            },
            {
              "type": "string",
              "const": "asc"
            },
            {
              "type": "string",
              "const": "desc"
            },
            {
              "type": "string",
              "const": "ascending"
            },
            {
              "type": "string",
              "const": "descending"
            },
            {
              "type": "object",
              "properties": {
                "$meta": {
                  "type": "string"
                }
              },
              "required": [
                "$meta"
              ]
            }
          ]
        }
      },
      "responseBytesLimit": {
        "default": 1048576,
        "type": "number"
      }
    },
    "required": [
      "database",
      "collection"
    ]
  }
}